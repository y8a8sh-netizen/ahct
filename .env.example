# Frontend environment variables
# Use backend root URL only (no /api suffix)
VITE_API_BASE_URL=https://ahct.onrender.com

# Backend environment variable for remote database connection (Supabase on Render)
DATABASE_URL=postgres://postgres:admin123@localhost:5432/college_scheduler

# Secret for JWT auth tokens (set a strong random value in production)
JWT_SECRET=change-me-in-production

# Geo restriction — enable on Vercel + Render in production
GEO_RESTRICT_SA=false
GEO_BLOCK_VPN=true
